{
  "Logging": {
    "LogLevel": {
      "Default": "Critical",
      "Microsoft.AspNetCore": "Critical"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AZOA": {
    "DebugErrors": false
  },
  "DataProtection": {
    "ApplicationName": "AZOA.WebAPI.NodeTransparency.v1",
    "KeyRingPath": "/app/data/data-protection-keys"
  },
  "Diagnostics": {
    "JsonlExceptionLogger": {
      "Enabled": true,
      "Directory": "logs/exceptions"
    }
  }
}

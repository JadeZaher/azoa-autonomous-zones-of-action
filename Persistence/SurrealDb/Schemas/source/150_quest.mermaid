erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "Quest (Models/Quest/Quest.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL; definition-side workflow shape. Runtime state lives on quest_run + quest_node_execution per quest-temporal-fork-model ADR §1."
    %% @surreal.note "Shape-only definition: name, owner, template ancestry, dapp-series binding, free-form metadata. status/completed_date were intentionally removed when quest-temporal-fork-model split runtime from definition -- see SURREAL-SCHEMA-HINTS.md §1 'Removed from quest'."
    %% @surreal.note "nodes/edges/dependencies live in their own tables (quest_node, quest_edge, quest_dependency) keyed by quest_id -- they are queried independently of the parent and mutated through Add/Remove endpoints. Embedding them would force the controller-side node/edge CRUD endpoints to read-modify-write the entire quest row."
    %% @surreal.note "metadata is a free-form string->string map for caller-supplied tags (e.g. UI color, sort hint). Persisted as a SurrealDB object to keep arbitrary keys queryable."
    quest {
        %% @surreal.fieldgroup "Core identity (record id is the Guid('N') of Quest.Id)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.fieldgroup "Caller-supplied label"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string name
        %% @surreal.fieldgroup "Optional description"
        option<string> description
        %% @surreal.fieldgroup "Owner avatar (Guid('N') hex)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string avatar_id
        %% @surreal.fieldgroup "Source template id when instantiated from a QuestTemplate (null for hand-authored quests)"
        option<string> template_id
        %% @surreal.fieldgroup "Owning DappSeries when this quest is part of a composed dApp (null for standalone quests)"
        option<string> dapp_series_id
        %% @surreal.fieldgroup "Free-form caller-supplied metadata (string->string map)"
        object metadata
        %% @surreal.fieldgroup "Definition birthdate -- STAYS on the definition, not a runtime artifact"
        datetime created_date
        %% @surreal.index fields=[avatar_id] name=quest_by_avatar
        %% @surreal.index fields=[template_id] name=quest_by_template
        %% @surreal.index fields=[dapp_series_id] name=quest_by_dapp_series
    }

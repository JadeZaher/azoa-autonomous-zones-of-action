erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "Holon (Models/Holon.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL"
    %% @surreal.note "ParentHolon / SubHolons are navigation properties from EF -- not persisted. Polyhierarchy graph remodel lives in surrealdb-migration task 10."
    %% @surreal.slice "identity"
    holon {
        string id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string name
        string description
        option<string> parent_holon_id
        option<string> avatar_id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string provider_name
        option<string> chain_id
        option<string> asset_type
        option<string> token_id
        %% @surreal.fieldgroup "Metadata (flexible key->value bag)"
        option<object> metadata
        %% @surreal.fieldgroup "PeerHolonIds (list of holon-id strings)"
        option<array<string>> peer_holon_ids
        %% @surreal.fieldgroup "Embedding vector for HNSW semantic search (384-dimensional, MiniLM-style)"
        %% @surreal.note "Populated by the MCP vector_search pipeline; absent until first embed call. HNSW index defined in 240_hnsw_indexes.surql."
        %% @surreal.csharp.skip
        option<array<float>> embedding
        datetime created_date
        option<datetime> modified_date
        %% @surreal.default "true"
        bool is_active
        %% @surreal.index fields=[avatar_id] name=holon_avatar_id
        %% @surreal.index fields=[parent_holon_id] name=holon_parent
        %% @surreal.index fields=[provider_name,chain_id] name=holon_provider_chain
        %% @surreal.index fields=[asset_type] name=holon_asset_type
    }

    avatar ||--o{ holon : "owns"
    holon  o|--o{ holon : "parent / sub (polyhierarchy)"

erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "AvatarNFT (Models/AvatarNFT.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL"
    %% @surreal.note "is_current distinguishes live ownership from historical transfer rows. Adapter enforces the (chain, contract, token_id, is_current=true) singleton invariant."
    %% @surreal.note "B3 review: nft_chain_contract_token_current is intentionally NOT UNIQUE because is_current=false rows accumulate as transfer history; uniqueness of the (chain, contract, token_id, is_current=true) tuple is enforced by the adapter setting is_current=false on the prior row before inserting the new one (SurrealDB does not support partial UNIQUE INDEXes)."
    nft_ownership {
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string avatar_id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string chain_type
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string contract_address
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string token_id
        %% @surreal.fieldgroup "Token standard (ERC721, ERC1155, ARC3, ...)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string token_standard
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string metadata_uri
        option<string> image_uri
        option<string> name
        option<string> description
        %% @surreal.fieldgroup "Attributes (flexible key->value bag)"
        option<object> attributes
        %% @surreal.default "0.0"
        decimal royalty_percentage
        option<string> royalty_recipient
        %% @surreal.default "false"
        bool is_soulbound
        %% @surreal.default "true"
        bool is_transferable
        %% @surreal.fieldgroup "is_current: true = live ownership; false = historical"
        %% @surreal.default "true"
        bool is_current
        option<string> current_owner
        %% @surreal.default "true"
        bool is_active
        datetime minted_date
        option<datetime> last_transfer_date
        %% @surreal.index fields=[chain_type,contract_address,token_id,is_current] name=nft_chain_contract_token_current
        %% @surreal.index fields=[avatar_id] name=nft_avatar_id
        %% @surreal.index fields=[chain_type,contract_address] name=nft_chain_contract
    }

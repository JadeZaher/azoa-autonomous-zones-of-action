erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "QuestEdge (Models/Quest/QuestEdge.cs)"
    %% @surreal.guardrail "G6 SCHEMAFULL; definition-side directed control-flow edge between two quest_node rows in the same quest."
    %% @surreal.note "Scalar edge table is the conservative shape; the surrealdb-migration track may promote this to a native `RELATE source_node -> control_flow -> target_node` edge for cheaper traversal. Both shapes preserve intra-iteration DAG semantics; the scalar form keeps QuestDagValidator queries unchanged."
    %% @surreal.note "condition is populated only when edge_type = Conditional; the ConditionNodeHandler evaluates the expression against the upstream node's serialized output to gate edge activation."
    quest_edge {
        %% @surreal.fieldgroup "Core identity (record id is the Guid('N') of QuestEdge.Id)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.fieldgroup "Owning quest"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string quest_id
        %% @surreal.fieldgroup "Upstream node"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string source_node_id
        %% @surreal.fieldgroup "Downstream node"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string target_node_id
        %% @surreal.fieldgroup "Optional condition expression (only with edge_type=Conditional)"
        option<string> condition
        %% @surreal.fieldgroup "QuestEdgeType enum name"
        %% @surreal.assert "$value INSIDE [\"Control\", \"Conditional\"]"
        %% @surreal.default "\"Control\""
        string edge_type
        %% @surreal.index fields=[quest_id] name=quest_edge_by_quest
        %% @surreal.index fields=[source_node_id] name=quest_edge_by_source
        %% @surreal.index fields=[target_node_id] name=quest_edge_by_target
    }

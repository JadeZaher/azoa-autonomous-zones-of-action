erDiagram
    %% @surreal.schemafull
    %% @surreal.aggregate "Swap order/quote state (SwapQuoteRequest/SwapExecuteRequest/SwapQuoteResponse)"
    %% @surreal.guardrail "G6 SCHEMAFULL, G2 idempotency unique index"
    %% @surreal.note "Status uses OperationStatus constants; minimal durable state for replay + idempotency."
    %% @surreal.note "B3 review: swap_state_idempotency_key UNIQUE on option<string>. Same NULL-collision caveat as bridge_tx: the swap-execute flow MUST supply an idempotency_key (api-safety-hardening §4 validator); NULL rows are diagnostic-only and the claim path never inserts NULL."
    swap_state {
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string avatar_id
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string chain
        %% @surreal.fieldgroup "Source/target token pair"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string token_in
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string token_out
        %% @surreal.fieldgroup "Amounts (strings -- arbitrary precision)"
        %% @surreal.assert "$value != NONE AND $value != \"\""
        string amount_in
        option<string> expected_amount_out
        option<string> actual_amount_out
        %% @surreal.fieldgroup "Slippage in basis points"
        %% @surreal.default "50"
        int slippage_bps
        %% @surreal.fieldgroup "Wallet executing the swap"
        option<string> wallet_address
        %% @surreal.fieldgroup "Quote reference (chain-side opaque)"
        option<string> quote_id
        %% @surreal.fieldgroup "Status (OperationStatus constants)"
        %% @surreal.assert "$value INSIDE [\"Pending\", \"Unknown\", \"Failed\", \"Completed\", \"AwaitingSignature\", \"Minted\", \"Burned\", \"Exchanged\", \"Swapped\", \"Transferred\", \"Deployed\", \"Called\"]"
        %% @surreal.default "\"Pending\""
        string status
        %% @surreal.fieldgroup "G2 idempotency"
        option<string> idempotency_key
        option<string> error_message
        datetime created_at
        datetime updated_at
        option<datetime> completed_at
        %% @surreal.index unique fields=[idempotency_key] name=swap_state_idempotency_key
        %% @surreal.index fields=[avatar_id] name=swap_state_avatar_id
        %% @surreal.index fields=[status] name=swap_state_status
    }

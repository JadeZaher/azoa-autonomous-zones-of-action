{
  "stryker-config": {
    "project": "AZOA.WebAPI.csproj",
    "test-projects": [
      "tests/AZOA.WebAPI.Tests/AZOA.WebAPI.Tests.csproj"
    ],
    "reporters": ["html", "progress", "cleartext"],
    "mutation-level": "Standard",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 50
    },
    "mutate": [
      "!**/Migrations/**",
      "!**/Program.cs",
      "!**/Models/**"
    ],
    "coverage-analysis": "perTest",
    "disable-bail": false
  }
}

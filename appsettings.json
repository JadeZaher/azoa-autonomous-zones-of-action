  "AllowedHosts": "*",
  "DataProtection": {
    "ApplicationName": "AZOA.WebAPI.NodeTransparency.v1",
    "KeyRingPath": ""
  },
  "NodeConformance": {
    "__comment": "Disabled by default. Enabling the local-only L0 descriptor requires a durable dedicated node-identity directory and a read-only metadata-bound CI artifact bundle for G1/G2/G3/G5/G7. ExpectedRepository and ExpectedWorkflow must exactly match trusted CI; the running assembly revision must match metadata. This does not activate federation, a DHT, peers, or any wallet capability.",
    "Enabled": false,
    "NodeId": "",
    "KeyStoragePath": "",
    "EvidenceDirectory": "",
    "ExpectedRepository": "",
    "ExpectedWorkflow": "",
    "MaxEvidenceAgeMinutes": 1440,
    "ManifestLifetimeMinutes": 60,
    "MaxPayloadBytes": 16384
  },
  "NodeTransparencyHistory": {
    "__comment": "Disabled by default. This signed public checkpoint uses the dedicated NodeConformance identity and its protected durable directory; it never enables federation, paid egress, or value settlement.",
    "Enabled": false,
    "MaxAuditEntries": 512
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "TrustAll": false,
    "EdgeOnlyDeploymentAcknowledged": false,
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },

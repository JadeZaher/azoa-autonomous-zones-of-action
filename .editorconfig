# EditorConfig — AZOA code style + enforcement
# Top-most config; nothing above this is consulted.
root = true

# ─────────────────────────────────────────────────────────────────────────────
# Baseline for every text file
# ─────────────────────────────────────────────────────────────────────────────
[*]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf            # committed text is LF (.gitattributes `* text=auto`)

[*.{csproj,props,targets,xml,config}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{ps1,cmd,bat}]
end_of_line = crlf          # Windows-only scripts (mirrors .gitattributes)

[*.md]
trim_trailing_whitespace = false   # trailing spaces are markdown line breaks

# ─────────────────────────────────────────────────────────────────────────────
# C# — the house style. Severities chosen to ENFORCE the few rules that matter
# and merely SUGGEST the stylistic ones, so the build surfaces real problems
# (dead usings) without a warning flood. EnforceCodeStyleInBuild (Directory.Build.props)
# makes these visible in `dotnet build` / CI.
# ─────────────────────────────────────────────────────────────────────────────
[*.cs]

# ── Enforced (warning) — caught at build time ────────────────────────────────
# Unused usings: the repo's role-first reorg left some; keep them out going forward.
dotnet_diagnostic.IDE0005.severity = warning
# Language/runtime correctness niceties worth enforcing (low/zero existing violations).
dotnet_diagnostic.IDE0035.severity = warning   # unreachable code
dotnet_diagnostic.IDE0051.severity = warning   # unused private member
dotnet_diagnostic.IDE0052.severity = warning   # unread private member

# File-scoped namespaces are PREFERRED for new code, but ~76 existing files use the
# block form — keep this a suggestion (not warning) to avoid a flag-day conversion.
csharp_style_namespace_declarations = file_scoped:suggestion
dotnet_diagnostic.IDE0161.severity = suggestion

# ── using directives ─────────────────────────────────────────────────────────
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# ── Suggested (won't churn the existing tree) ────────────────────────────────
# `var` — repo mixes; suggest explicit-where-apparent, don't enforce.
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
# Modern C# expression styles — suggestions only.
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_prefer_braces = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
# `this.` is not used in this codebase.
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion
# Prefer readonly fields, predefined types.
dotnet_style_readonly_field = true:suggestion
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# ── New-line / spacing formatting (apply on format, not enforced as warnings) ─
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_space_after_keywords_in_control_flow_statements = true

# ─────────────────────────────────────────────────────────────────────────────
# Naming conventions (the contract): interfaces I-prefixed, types/methods
# PascalCase, private fields _camelCase, constants PascalCase.
# ─────────────────────────────────────────────────────────────────────────────
dotnet_naming_rule.interfaces_should_be_prefixed_i.severity = warning
dotnet_naming_rule.interfaces_should_be_prefixed_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_should_be_prefixed_i.style = i_prefixed_pascal
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_symbols.interface_symbols.applicable_accessibilities = *
dotnet_naming_style.i_prefixed_pascal.required_prefix = I
dotnet_naming_style.i_prefixed_pascal.capitalization = pascal_case

dotnet_naming_rule.types_pascal.severity = suggestion
dotnet_naming_rule.types_pascal.symbols = type_symbols
dotnet_naming_rule.types_pascal.style = pascal
dotnet_naming_symbols.type_symbols.applicable_kinds = class,struct,enum,delegate
dotnet_naming_style.pascal.capitalization = pascal_case

dotnet_naming_rule.members_pascal.severity = suggestion
dotnet_naming_rule.members_pascal.symbols = member_symbols
dotnet_naming_rule.members_pascal.style = pascal
dotnet_naming_symbols.member_symbols.applicable_kinds = method,property,event

dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_rule.private_fields_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization = camel_case

# ─────────────────────────────────────────────────────────────────────────────
# Generated + vendored code — never enforce style here.
# ─────────────────────────────────────────────────────────────────────────────
[Persistence/SurrealDb/Generated/**]
generated_code = true

[**/{bin,obj}/**]
generated_code = true

[frontend/**]
# Frontend has its own (Next.js/ESLint) tooling; .NET rules do not apply.
dotnet_analyzer_diagnostic.severity = none

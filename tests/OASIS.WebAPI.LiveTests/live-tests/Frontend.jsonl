# ═══════════════════════════════════════════════════════════════
# Frontend (Next.js) smoke tests.
# Hits absolute URLs at http://localhost:3000 so the suite is independent
# of the harness's BaseUrl (which is API-side). Asserts that each key
# route is reachable and returns HTML or the expected redirect — the
# goal is "the frontend is up and serving the routes we depend on",
# not deep DOM assertions.
# Add deeper Playwright-style flow tests in a separate suite if/when
# the team wires Playwright into CI.
# ═══════════════════════════════════════════════════════════════

{"id":"fe_root","description":"Frontend root page loads (renders or redirects to a sign-in route)","method":"GET","path":"http://localhost:3000/","headers":{"Accept":"text/html"},"expectedStatusRange":"2xx"}
